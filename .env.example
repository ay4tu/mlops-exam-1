# ============================================================================
# ModelServe — Environment Variables
# ============================================================================

# PostgreSQL (MLflow backend store)
POSTGRES_USER=mlflow
POSTGRES_PASSWORD=<your-password>
POSTGRES_DB=mlflow

# MLflow
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_BACKEND_STORE_URI=postgresql+psycopg2://mlflow:<password>@localhost:5432/mlflow

# AWS (S3 artifact store — production only)
AWS_ACCESS_KEY_ID=<your-key>
AWS_SECRET_ACCESS_KEY=<your-secret>
AWS_REGION=us-east-1

# Redis (Feast online store — Phase 2)
REDIS_HOST=localhost
REDIS_PORT=6379

# FastAPI (Phase 2)
MODEL_NAME=fraud-detector
MODEL_STAGE=Production

# Grafana (Phase 3)
GRAFANA_PASSWORD=admin
